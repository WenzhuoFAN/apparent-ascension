---
import BaseLayout from "../../layouts/BaseLayout.astro";
import NavBar from "../../components/NavBar.astro";
import Section from "../../components/Section.astro";

import { getStreamRecords } from "../../lib/streams-store";
import { formatDateCN } from "../../utils/date";

const items = await getStreamRecords();

const memberNameMap = {
  fiona: "心宜",
  gladys: "思诺",
  both: "双人",
} as const;

function formatMoney(value: number | undefined) {
  if (!value || value <= 0) return "¥0.00";
  return `¥${value.toLocaleString("zh-CN", { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
}
---
<BaseLayout title="直播记录｜闪耀舞台" description="每场直播记录与核心数据">
  <NavBar slot="nav" active="streams" />

  <h1 class="h1">直播记录 📼</h1>

  <div class="member-filter" data-member-filter-root>
    <button type="button" class="chip active" data-member="all">全部</button>
    <button type="button" class="chip" data-member="fiona">心宜</button>
    <button type="button" class="chip" data-member="gladys">思诺</button>
  </div>

  <Section title="历史直播" subtitle="按日期倒序。">
    <div class="list">
      {items.map((s) => (
        <a class="row" href={`/streams/${s.slug}`} data-member-item data-member={s.member}>
          <div class="when">{formatDateCN(s.date)}</div>
          <div class="what">
            <div class="t">{s.title}</div>
            <div class="meta">
              <span class="pill">{memberNameMap[s.member]}</span>
              {s.durationMin && <span class="pill faint">{s.durationMin} min</span>}
              {s.replayUrl ? <span class="pill faint">有回放</span> : <span class="pill faint">回放待补</span>}
              {s.source === "live-db" && <span class="pill auto">自动采集</span>}
            </div>

            {(s.danmakuCount || s.peakRealtimeViewers || s.revenueCny) && (
              <div class="metrics">
                {typeof s.danmakuCount === "number" && <span>弹幕 {s.danmakuCount.toLocaleString()}</span>}
                {typeof s.peakRealtimeViewers === "number" && (
                  <span>峰值观看 {s.peakRealtimeViewers.toLocaleString()}</span>
                )}
                {typeof s.revenueCny === "number" && <span>营收 {formatMoney(s.revenueCny)}</span>}
              </div>
            )}

            {s.highlights?.length ? (
              <div class="hl">亮点：{s.highlights.slice(0, 2).join(" / ")}</div>
            ) : (
              <div class="hl faint">{s.source === "live-db" ? "自动采集中（可后续补充亮点摘要）" : "暂无亮点摘要"}</div>
            )}
          </div>
          <div class="thumb">
            {s.member === "both" ? (
              <div class="thumb-both">
                <img src="/images/FionaLive.jpg" alt="心宜直播图" loading="lazy" decoding="async" />
                <img src="/images/GladysLive.jpg" alt="思诺直播图" loading="lazy" decoding="async" />
              </div>
            ) : s.member === "fiona" ? (
              <img src="/images/FionaLive.jpg" alt="心宜直播图" loading="lazy" decoding="async" />
            ) : (
              <img src="/images/GladysLive.jpg" alt="思诺直播图" loading="lazy" decoding="async" />
            )}
          </div>
        </a>
      ))}
    </div>

    {!items.length && <p class="p">还没有直播记录。先运行 `npm run collect:live` 采集数据。</p>}
  </Section>

  <script is:inline>
    (() => {
      const root = document.querySelector("[data-member-filter-root]");
      if (!root) return;

      const rows = Array.from(document.querySelectorAll("[data-member-item]"));
      let selected = "all";

      const matches = (member) => {
        if (selected === "all") return true;
        return member === selected || member === "both";
      };

      const apply = () => {
        rows.forEach((row) => {
          const member = row.getAttribute("data-member") || "both";
          row.style.display = matches(member) ? "" : "none";
        });
      };

      root.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const member = target.getAttribute("data-member");
        if (!member) return;

        selected = member;
        root.querySelectorAll("[data-member]").forEach((btn) => {
          btn.classList.toggle("active", btn.getAttribute("data-member") === selected);
        });
        apply();
      });

      apply();
    })();
  </script>

  <style lang="scss">
    @use "../../styles/mixins" as m;

    .member-filter {
      display: flex;
      gap: 8px;
      margin: 8px 0 14px;
      flex-wrap: wrap;
    }
    .chip {
      padding: 7px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(0, 0, 0, 0.22);
      color: rgba(255, 255, 255, 0.78);
      cursor: pointer;
      font-size: 13px;
      transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease);
    }
    .chip:hover {
      background: rgba(0, 0, 0, 0.33);
    }
    .chip.active {
      background: rgba(255, 255, 255, 0.16);
      border-color: rgba(255, 255, 255, 0.28);
      color: rgba(255, 255, 255, 0.95);
    }

    .list {
      display: grid;
      gap: 10px;
    }
    .row {
      @include m.glass;
      @include m.hover-float;
      border-radius: var(--r-lg);
      padding: 12px;
      display: grid;
      grid-template-columns: 140px 1fr 160px;
      gap: 12px;
      align-items: center;
    }
    .when {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.7);
    }
    .t {
      font-weight: 800;
      margin-bottom: 6px;
    }
    .meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .pill {
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(0, 0, 0, 0.18);
      color: rgba(255, 255, 255, 0.78);
    }
    .pill.faint {
      color: rgba(255, 255, 255, 0.62);
    }
    .pill.auto {
      border-color: rgba(137, 255, 190, 0.26);
      color: rgba(203, 255, 221, 0.9);
    }
    .metrics {
      margin-top: 8px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      font-size: 13px;
      color: rgba(211, 255, 224, 0.9);
    }
    .hl {
      margin-top: 8px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.7);
    }
    .hl.faint {
      color: rgba(255, 255, 255, 0.55);
    }

    .thumb {
      justify-self: end;
      width: 150px;
      height: 84px;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background: rgba(0, 0, 0, 0.2);
    }
    .thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .thumb-both {
      display: grid;
      grid-template-columns: 1fr 1fr;
      width: 100%;
      height: 100%;
    }
    .thumb-both img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 980px) {
      .row {
        grid-template-columns: 1fr;
      }
      .thumb {
        justify-self: start;
      }
    }
  </style>
</BaseLayout>

