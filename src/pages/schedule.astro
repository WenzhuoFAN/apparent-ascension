---
import NavBar from "../components/NavBar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAdminSession } from "../lib/admin-auth";

const initialIsAdmin = Boolean(await getAdminSession(Astro));
const pageDescription = "自动同步官方周表与预约动态，管理员登录后可校对和修正。";
const defaultImportMid = "3493085336046382,3537115310721181,3537115310721781";
const roomCoverMap = {
  fiona: "/images/FionaLive.jpg",
  gladys: "/images/GladysLive.jpg",
};
---
<BaseLayout title="日程表｜闪耀舞台" description={pageDescription}>
  <NavBar slot="nav" active="schedule" />

  <section class="schedule-shell">
    <header class="page-head">
      <h1 class="h1">直播日程表 🗓️</h1>
      <p class="p">{pageDescription}</p>
    </header>

    <section class="calendar-panel">
      <div class="toolbar">
        <div>
          <h2 class="h2">本月日历</h2>
          <div class="month" id="calendar-month-label">--</div>
        </div>

        {
          initialIsAdmin && (
            <div class="admin-tools" id="admin-tools">
              <input id="import-mids-input" type="text" value={defaultImportMid} placeholder="MID，逗号分隔" />
              <input id="import-year-input" type="number" min="2024" max="2100" />
              <button class="btn primary" id="import-schedule" type="button">从动态导入</button>
              <button class="btn" id="open-editor" type="button">手动新增</button>
            </div>
          )
        }
      </div>

      <p class="status" id="import-status" hidden={!initialIsAdmin}></p>

      <div class="calendar-layout" id="calendar-layout">
        <div class="board">
        <div class="weekdays">
          <span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span><span>日</span>
        </div>
        <div class="calendar-grid" id="calendar-grid"></div>
        </div>

        <aside class="detail-panel" id="detail-panel" hidden>
          <div class="detail-head">
            <div>
              <div class="detail-kicker">当日安排</div>
              <h3 class="detail-date" id="detail-date-label">--</h3>
            </div>
            <div class="detail-head-actions">
              <button class="btn detail-add-btn" id="detail-add-entry" type="button" hidden>为这一天新增</button>
              <button class="btn detail-close-btn" id="detail-close" type="button">收起</button>
            </div>
          </div>

          <p class="detail-meta" id="detail-meta-label">--</p>
          <div class="detail-list" id="detail-list"></div>
          <p class="detail-empty" id="detail-empty">当天暂无安排。</p>
        </aside>
      </div>
    </section>
  </section>

  {
    initialIsAdmin && (
      <div class="modal" id="editor-modal" hidden>
        <div class="modal-panel">
          <div class="modal-head">
            <h3 id="editor-title-text">日程编辑</h3>
            <button class="icon-btn" id="close-editor" type="button" aria-label="关闭">×</button>
          </div>

          <label class="field">
            <span>标题</span>
            <input id="title-input" type="text" placeholder="例如：花与歌 / 有点宜思的世界" />
          </label>

          <div class="field-row">
            <label class="field">
              <span>日期</span>
              <input id="date-input" type="date" />
            </label>
            <label class="field">
              <span>时间</span>
              <input id="time-input" type="time" step="600" />
            </label>
          </div>

          <div class="field-row">
            <label class="field">
              <span>直播间</span>
              <select id="room-input">
                <option value="fiona">心宜</option>
                <option value="gladys">思诺</option>
                <option value="both">双人</option>
              </select>
            </label>
            <label class="field">
              <span>分类（可选）</span>
              <input id="category-input" type="text" placeholder="歌回 / 杂谈 / 游戏 / 联动" />
            </label>
          </div>

          <p class="source-note" id="source-summary" hidden></p>

          <div class="modal-actions">
            <button class="btn primary" id="save-entry" type="button">保存</button>
            <button class="btn danger" id="delete-entry" type="button" hidden>删除</button>
            <button class="btn" id="cancel-editor" type="button">取消</button>
          </div>
        </div>
      </div>
    )
  }

  <script define:vars={{ initialIsAdmin, roomCoverMap, defaultImportMid }}>
    (() => {
      const CONTENT_KEY = "schedule.manual.entries.v3";
      const state = { entries: [], isAdmin: Boolean(initialIsAdmin), editingId: "", selectedDate: "" };
      const covers = roomCoverMap || {};
      const roomLabel = { fiona: "心宜", gladys: "思诺", both: "心宜 / 思诺" };
      const roomEmoji = { fiona: "🦭", gladys: "🐚" };
      const now = new Date();
      const year = now.getFullYear();
      const month = now.getMonth() + 1;
      const today = `${year}-${String(month).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;

      const $ = (id) => document.getElementById(id);
      const monthLabel = $("calendar-month-label");
      const calendarLayout = $("calendar-layout");
      const calendarGrid = $("calendar-grid");
      const detailPanel = $("detail-panel");
      const detailDateLabel = $("detail-date-label");
      const detailMetaLabel = $("detail-meta-label");
      const detailList = $("detail-list");
      const detailEmpty = $("detail-empty");
      const detailAddBtn = $("detail-add-entry");
      const detailCloseBtn = $("detail-close");
      const importStatus = $("import-status");
      const adminTools = $("admin-tools");
      const importMidsInput = $("import-mids-input");
      const importYearInput = $("import-year-input");
      const importBtn = $("import-schedule");
      const openBtn = $("open-editor");
      const modal = $("editor-modal");
      const editorTitleText = $("editor-title-text");
      const closeBtn = $("close-editor");
      const cancelBtn = $("cancel-editor");
      const saveBtn = $("save-entry");
      const deleteBtn = $("delete-entry");
      const titleInput = $("title-input");
      const dateInput = $("date-input");
      const timeInput = $("time-input");
      const roomInput = $("room-input");
      const categoryInput = $("category-input");
      const sourceSummary = $("source-summary");

      if (!monthLabel || !calendarLayout || !calendarGrid || !detailPanel || !detailDateLabel || !detailMetaLabel || !detailList || !detailEmpty) return;

      const pad2 = (n) => String(n).padStart(2, "0");
      const entryId = (row) => String(row.id || [row.date, row.time, row.room, row.title].join("|"));
      const contentUrl = (admin = false) => `${admin ? "/api/admin/content/" : "/api/content/"}${encodeURIComponent(CONTENT_KEY)}`;
      const sortEntries = (rows) => [...rows].sort((a, b) => `${a.date}T${a.time}`.localeCompare(`${b.date}T${b.time}`) || a.id.localeCompare(b.id));
      const normalizeTime = (value) => {
        const m = String(value || "").match(/^(\d{2}):(\d{2})$/);
        if (!m) return "";
        let hh = Number(m[1]);
        let mm = Math.round(Number(m[2]) / 10) * 10;
        if (mm >= 60) { mm = 0; hh = (hh + 1) % 24; }
        return `${pad2(hh)}:${pad2(mm)}`;
      };

      const normalize = (row) => {
        if (!row || typeof row !== "object") return null;
        const title = String(row.title || "").trim();
        const date = String(row.date || "").trim();
        const time = String(row.time || "").trim();
        const room = row.room === "both" ? "both" : row.room === "gladys" ? "gladys" : row.room === "fiona" ? "fiona" : null;
        if (!title || !/^\d{4}-\d{2}-\d{2}$/.test(date) || !/^\d{2}:\d{2}$/.test(time) || !room) return null;
        return {
          id: entryId({ ...row, title, date, time, room }),
          title,
          date,
          time,
          room,
          category: String(row.category || row.type || "").trim(),
          mode: String(row.mode || "").trim(),
          sourceType: row.sourceType === "auto" ? "auto" : "manual",
          sourceDynamicId: String(row.sourceDynamicId || "").trim(),
          sourceUrl: String(row.sourceUrl || "").trim(),
          updatedAt: String(row.updatedAt || "").trim(),
        };
      };

      const fetchJson = async (url, init = {}) => {
        const response = await fetch(url, { cache: "no-store", ...init });
        let payload = null;
        try { payload = await response.json(); } catch { payload = null; }
        return { response, payload };
      };

      const setStatus = (message = "", error = false) => {
        if (!importStatus) return;
        importStatus.hidden = !message;
        importStatus.textContent = message;
        importStatus.classList.toggle("is-error", !!error);
      };

      const syncAdminUi = () => {
        if (adminTools) adminTools.hidden = !state.isAdmin;
        if (detailAddBtn) detailAddBtn.hidden = true;
        if (!state.isAdmin && importStatus) importStatus.hidden = true;
      };

      const loadAdminState = async () => {
        try {
          const { response, payload } = await fetchJson("/api/admin/session");
          state.isAdmin = response.ok && !!payload?.authenticated;
        } catch {
          state.isAdmin = false;
        }
        syncAdminUi();
      };

      const handleAdminExpired = () => {
        state.isAdmin = false;
        syncAdminUi();
        if (modal) modal.hidden = true;
        setStatus("管理员会话已失效，请重新登录 /admin。", true);
        renderAll();
      };

      const persistEntries = async (rows) => {
        if (!state.isAdmin) {
          alert("请先登录管理员账号：/admin");
          return false;
        }
        const { response, payload } = await fetchJson(contentUrl(true), {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ data: sortEntries(rows) }),
        });
        if (response.status === 401) return handleAdminExpired(), false;
        if (!response.ok || !payload?.ok || !Array.isArray(payload.data)) {
          alert(`保存失败：${payload?.message || response.statusText}`);
          return false;
        }
        state.entries = sortEntries(payload.data.map(normalize).filter(Boolean));
        return true;
      };

      const groupEntries = (entries) => {
        const map = new Map();
        for (const entry of sortEntries(entries)) {
          const key = entry.date;
          const bucket = map.get(key) || [];
          bucket.push(entry);
          map.set(key, bucket);
        }
        return map;
      };

      const createCover = (entry) => {
        const wrap = document.createElement("div");
        wrap.className = "event-cover" + (entry.room === "both" ? " is-both" : "");
        const appendImg = (src) => {
          if (!src) return;
          const img = document.createElement("img");
          img.src = src;
          img.alt = "";
          img.loading = "lazy";
          img.className = "event-cover-image";
          img.onerror = () => img.remove();
          wrap.appendChild(img);
        };
        if (entry.room === "both") {
          appendImg(String(covers.fiona || ""));
          appendImg(String(covers.gladys || ""));
        } else {
          appendImg(entry.room === "gladys" ? String(covers.gladys || "") : String(covers.fiona || ""));
        }
        if (!wrap.children.length) {
          const fallback = document.createElement("div");
          fallback.className = "event-cover-fallback";
          fallback.textContent = roomLabel[entry.room] || "直播";
          wrap.appendChild(fallback);
        }
        return wrap;
      };

      const openCreate = (dateValue = today) => {
        if (!state.isAdmin || !modal || !editorTitleText || !titleInput || !dateInput || !timeInput || !roomInput || !categoryInput || !sourceSummary || !deleteBtn) return;
        state.editingId = "";
        editorTitleText.textContent = "手动新增日程";
        titleInput.value = "";
        dateInput.value = dateValue;
        timeInput.value = "20:00";
        roomInput.value = "fiona";
        categoryInput.value = "";
        sourceSummary.hidden = true;
        sourceSummary.textContent = "";
        deleteBtn.hidden = true;
        modal.hidden = false;
      };

      const openEdit = (entry) => {
        if (!state.isAdmin || !modal || !editorTitleText || !titleInput || !dateInput || !timeInput || !roomInput || !categoryInput || !sourceSummary || !deleteBtn) return;
        state.editingId = entry.id;
        editorTitleText.textContent = "编辑日程";
        titleInput.value = entry.title;
        dateInput.value = entry.date;
        timeInput.value = entry.time;
        roomInput.value = entry.room;
        categoryInput.value = entry.category || "";
        sourceSummary.hidden = !(entry.sourceDynamicId || entry.sourceUrl);
        sourceSummary.textContent = entry.sourceUrl || entry.sourceDynamicId || "";
        deleteBtn.hidden = false;
        modal.hidden = false;
      };

      const renderCalendar = (entries) => {
        monthLabel.textContent = `${year}年${month}月`;
        calendarGrid.innerHTML = "";
        const byDate = groupEntries(entries.filter((entry) => entry.date.startsWith(`${year}-${pad2(month)}-`)));
        const firstDay = new Date(year, month - 1, 1);
        const daysInMonth = new Date(year, month, 0).getDate();
        const start = (firstDay.getDay() + 6) % 7;

        for (let i = 0; i < start; i += 1) {
          const blank = document.createElement("div");
          blank.className = "cal-cell is-empty";
          calendarGrid.appendChild(blank);
        }

        for (let day = 1; day <= daysInMonth; day += 1) {
          const dateKey = `${year}-${pad2(month)}-${pad2(day)}`;
          const dayEntries = byDate.get(dateKey) || [];
          const cell = document.createElement("div");
          cell.className = `cal-cell${dateKey === today ? " is-today" : ""}${dayEntries.length ? " has-events" : ""}`;

          const head = document.createElement("div");
          head.className = "cal-head";
          const dayEl = document.createElement("div");
          dayEl.className = "cal-day";
          dayEl.textContent = String(day);
          const marks = document.createElement("div");
          marks.className = "cal-marks";
          const roomSet = new Set();
          dayEntries.forEach((entry) => {
            if (entry.room === "both") { roomSet.add("fiona"); roomSet.add("gladys"); } else { roomSet.add(entry.room); }
          });
          ["fiona", "gladys"].forEach((room) => {
            if (!roomSet.has(room)) return;
            const mark = document.createElement("span");
            mark.className = `cal-mark ${room}`;
            mark.textContent = roomEmoji[room] || "•";
            marks.appendChild(mark);
          });
          head.append(dayEl, marks);
          cell.appendChild(head);

          const eventsWrap = document.createElement("div");
          eventsWrap.className = "cal-events";

          dayEntries.forEach((entry) => {
            const card = document.createElement(state.isAdmin ? "button" : "article");
            card.className = `event-card room-${entry.room}`;
            if (state.isAdmin) {
              card.type = "button";
              card.addEventListener("click", () => openEdit(entry));
            }

            const meta = document.createElement("div");
            meta.className = "event-meta";
            const time = document.createElement("span");
            time.className = "event-time";
            time.textContent = entry.time;
            const room = document.createElement("span");
            room.className = "event-room";
            room.textContent = roomLabel[entry.room] || "直播";
            meta.append(time, room);

            const title = document.createElement("div");
            title.className = "event-title";
            title.textContent = entry.title;

            const body = document.createElement("div");
            body.className = "event-body";
            body.append(meta, title);

            if (entry.mode || entry.category || state.isAdmin) {
              const badges = document.createElement("div");
              badges.className = "event-badges";
              const source = document.createElement("span");
              source.className = `event-badge source${entry.sourceType === "auto" ? " auto" : ""}`;
              source.textContent = entry.sourceType === "auto" ? "自动" : "手动";
              badges.appendChild(source);
              if (!state.isAdmin) source.remove();
              if (entry.mode) {
                const mode = document.createElement("span");
                mode.className = "event-badge mode";
                mode.textContent = entry.mode;
                badges.appendChild(mode);
              }
              if (entry.category) {
                const category = document.createElement("span");
                category.className = "event-badge";
                category.textContent = entry.category;
                badges.appendChild(category);
              }
              body.appendChild(badges);
            }

            card.append(createCover(entry), body);
            eventsWrap.appendChild(card);
          });

          cell.appendChild(eventsWrap);
          calendarGrid.appendChild(cell);
        }
      };

      const weekdayLabel = ["周日", "周一", "周二", "周三", "周四", "周五", "周六"];
      const formatSelectedDate = (dateKey) => {
        const matched = String(dateKey || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!matched) return dateKey || "--";
        const date = new Date(Number(matched[1]), Number(matched[2]) - 1, Number(matched[3]));
        return `${Number(matched[2])}月${Number(matched[3])}日 ${weekdayLabel[date.getDay()]}`;
      };

      const createBadges = (entry) => {
        const badges = document.createElement("div");
        badges.className = "event-badges";

        if (entry.mode) {
          const mode = document.createElement("span");
          mode.className = "event-badge mode";
          mode.textContent = entry.mode;
          badges.appendChild(mode);
        }

        if (entry.category) {
          const category = document.createElement("span");
          category.className = "event-badge";
          category.textContent = entry.category;
          badges.appendChild(category);
        }

        if (state.isAdmin) {
          const source = document.createElement("span");
          source.className = `event-badge source${entry.sourceType === "auto" ? " auto" : ""}`;
          source.textContent = entry.sourceType === "auto" ? "自动" : "手动";
          badges.appendChild(source);
        }

        return badges.children.length ? badges : null;
      };

      const createDetailCard = (entry) => {
        const card = document.createElement(state.isAdmin ? "button" : "article");
        card.className = `event-card detail-card room-${entry.room}`;
        if (state.isAdmin) {
          card.type = "button";
          card.addEventListener("click", () => openEdit(entry));
        }

        const meta = document.createElement("div");
        meta.className = "event-meta";
        const time = document.createElement("span");
        time.className = "event-time";
        time.textContent = entry.time;
        const room = document.createElement("span");
        room.className = "event-room";
        room.textContent = roomLabel[entry.room] || "直播";
        meta.append(time, room);

        const title = document.createElement("div");
        title.className = "event-title detail-title";
        title.textContent = entry.title;

        const body = document.createElement("div");
        body.className = "event-body";
        body.append(meta, title);

        const badges = createBadges(entry);
        if (badges) body.appendChild(badges);

        card.append(createCover(entry), body);
        return card;
      };

      const renderDetail = (entriesByDate) => {
        const selectedDate = state.selectedDate;
        const hasSelection = Boolean(selectedDate);
        detailPanel.hidden = !hasSelection;
        calendarLayout.classList.toggle("has-detail", hasSelection);

        if (!selectedDate) {
          detailDateLabel.textContent = "--";
          detailMetaLabel.textContent = "";
          detailList.innerHTML = "";
          detailEmpty.hidden = false;
          detailEmpty.textContent = "点击日历查看当天安排";
          if (detailAddBtn) detailAddBtn.hidden = true;
          return;
        }

        const selectedEntries = entriesByDate.get(selectedDate) || [];

        detailDateLabel.textContent = formatSelectedDate(selectedDate);
        detailMetaLabel.textContent = selectedEntries.length
          ? `${selectedEntries.length} 场直播`
          : "当天暂无直播安排";

        detailList.innerHTML = "";
        detailEmpty.hidden = selectedEntries.length > 0;
        detailEmpty.textContent = state.isAdmin ? "当天暂无安排，可以直接新增一场直播。" : "当天暂无安排。";

        selectedEntries.forEach((entry) => {
          detailList.appendChild(createDetailCard(entry));
        });

        if (detailAddBtn) {
          detailAddBtn.hidden = !state.isAdmin;
          detailAddBtn.onclick = () => openCreate(selectedDate);
        }
      };

      const renderOverview = (entries) => {
        monthLabel.textContent = `${year}年${month}月`;
        calendarGrid.innerHTML = "";
        const monthPrefix = `${year}-${pad2(month)}-`;
        const monthEntries = entries.filter((entry) => entry.date.startsWith(monthPrefix));
        const byDate = groupEntries(monthEntries);
        if (state.selectedDate && !state.selectedDate.startsWith(monthPrefix)) state.selectedDate = "";
        const previewLimit = state.selectedDate ? 1 : 2;
        const firstDay = new Date(year, month - 1, 1);
        const daysInMonth = new Date(year, month, 0).getDate();
        const start = (firstDay.getDay() + 6) % 7;

        for (let i = 0; i < start; i += 1) {
          const blank = document.createElement("div");
          blank.className = "cal-cell is-empty";
          calendarGrid.appendChild(blank);
        }

        for (let day = 1; day <= daysInMonth; day += 1) {
          const dateKey = `${year}-${pad2(month)}-${pad2(day)}`;
          const dayEntries = byDate.get(dateKey) || [];
          const cell = document.createElement("button");
          cell.type = "button";
          cell.className = `cal-cell cal-overview${dateKey === today ? " is-today" : ""}${dayEntries.length ? " has-events" : ""}${state.selectedDate === dateKey ? " is-selected" : ""}`;
          cell.addEventListener("click", () => {
            state.selectedDate = state.selectedDate === dateKey ? "" : dateKey;
            renderAll();
          });

          const head = document.createElement("div");
          head.className = "cal-head";
          const dayEl = document.createElement("div");
          dayEl.className = "cal-day";
          dayEl.textContent = String(day);
          const marks = document.createElement("div");
          marks.className = "cal-marks";
          const roomSet = new Set();
          dayEntries.forEach((entry) => {
            if (entry.room === "both") {
              roomSet.add("fiona");
              roomSet.add("gladys");
            } else {
              roomSet.add(entry.room);
            }
          });
          ["fiona", "gladys"].forEach((room) => {
            if (!roomSet.has(room)) return;
            const mark = document.createElement("span");
            mark.className = `cal-mark ${room}`;
            mark.textContent = roomEmoji[room] || "•";
            marks.appendChild(mark);
          });
          head.append(dayEl, marks);
          cell.appendChild(head);

          const summary = document.createElement("div");
          summary.className = "cal-summary";

          if (!dayEntries.length) {
            const empty = document.createElement("div");
            empty.className = "cal-empty-copy";
            empty.textContent = " ";
            summary.appendChild(empty);
          } else {
            dayEntries.slice(0, previewLimit).forEach((entry) => {
              const item = document.createElement("div");
              item.className = `summary-item room-${entry.room}`;

              const top = document.createElement("div");
              top.className = "summary-top";
              const time = document.createElement("span");
              time.className = "summary-time";
              time.textContent = entry.time;
              const room = document.createElement("span");
              room.className = "summary-room";
              room.textContent = roomLabel[entry.room] || "直播";
              top.append(time, room);

              const title = document.createElement("div");
              title.className = "summary-title";
              title.textContent = entry.title;

              item.append(top, title);
              summary.appendChild(item);
            });

            if (dayEntries.length > previewLimit) {
              const more = document.createElement("div");
              more.className = "summary-more";
              more.textContent = `还有 ${dayEntries.length - previewLimit} 场`;
              summary.appendChild(more);
            }
          }

          cell.appendChild(summary);
          calendarGrid.appendChild(cell);
        }

        renderDetail(byDate);
      };

      const renderAll = () => {
        state.entries = sortEntries(state.entries);
        renderOverview(state.entries);
      };

      const loadEntries = async () => {
        const { response, payload } = await fetchJson(contentUrl(false));
        if (!response.ok || !payload?.ok || !Array.isArray(payload.data)) {
          state.entries = [];
          return;
        }
        state.entries = sortEntries(payload.data.map(normalize).filter(Boolean));
      };

      if (importYearInput) importYearInput.value = String(year);
      if (openBtn) openBtn.addEventListener("click", () => openCreate());
      if (detailCloseBtn) detailCloseBtn.addEventListener("click", () => {
        state.selectedDate = "";
        renderAll();
      });
      if (closeBtn && modal) closeBtn.addEventListener("click", () => { modal.hidden = true; });
      if (cancelBtn && modal) cancelBtn.addEventListener("click", () => { modal.hidden = true; });
      if (modal) modal.addEventListener("click", (event) => { if (event.target === modal) modal.hidden = true; });
      window.addEventListener("keydown", (event) => { if (event.key === "Escape" && modal && !modal.hidden) modal.hidden = true; });

      if (saveBtn) {
        saveBtn.addEventListener("click", async () => {
          if (!state.isAdmin || !titleInput || !dateInput || !timeInput || !roomInput || !categoryInput) return;
          const title = String(titleInput.value || "").trim();
          const date = String(dateInput.value || "").trim();
          const time = normalizeTime(String(timeInput.value || "").trim()) || String(timeInput.value || "").trim();
          const room = roomInput.value === "both" ? "both" : roomInput.value === "gladys" ? "gladys" : "fiona";
          const category = String(categoryInput.value || "").trim();
          if (!title || !date || !time) return alert("请先填写标题、日期和时间。");

          let next = [...state.entries];
          if (state.editingId) {
            next = next.map((entry) => entry.id !== state.editingId ? entry : {
              ...entry,
              title,
              date,
              time,
              room,
              category,
              sourceType: "manual",
              updatedAt: new Date().toISOString(),
            });
          } else {
            next.push({
              id: globalThis.crypto?.randomUUID?.() || `manual-${Date.now()}`,
              title,
              date,
              time,
              room,
              category,
              sourceType: "manual",
              updatedAt: new Date().toISOString(),
            });
          }

          const ok = await persistEntries(next);
          if (!ok) return;
          renderAll();
          if (modal) modal.hidden = true;
        });
      }

      if (deleteBtn) {
        deleteBtn.addEventListener("click", async () => {
          if (!state.editingId) return;
          const target = state.entries.find((entry) => entry.id === state.editingId);
          if (!target || !confirm(`确定删除「${target.title}」吗？`)) return;
          const ok = await persistEntries(state.entries.filter((entry) => entry.id !== state.editingId));
          if (!ok) return;
          renderAll();
          if (modal) modal.hidden = true;
        });
      }

      if (importBtn) {
        importBtn.addEventListener("click", async () => {
          if (!state.isAdmin || !importMidsInput || !importYearInput) return;
          const mids = String(importMidsInput.value || defaultImportMid).split(",").map((x) => x.trim()).filter(Boolean);
          const importYear = Number(importYearInput.value || year);
          if (!mids.length) return setStatus("请至少填写一个 MID。", true);
          importBtn.disabled = true;
          setStatus("正在抓取动态并导入日程，请稍候…");
          try {
            const { response, payload } = await fetchJson("/api/admin/schedule/import", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ mids, year: importYear }),
            });
            if (response.status === 401) return handleAdminExpired();
            if (!response.ok || !payload?.ok || !Array.isArray(payload.data)) {
              return setStatus(`导入失败：${payload?.message || response.statusText}`, true);
            }
            state.entries = sortEntries(payload.data.map(normalize).filter(Boolean));
            renderAll();
            const summary = Array.isArray(payload.sources)
              ? payload.sources.map((item) => item.ok ? `${item.mid} 导入 ${item.importedCount} 条` : `${item.mid} 失败`).join("；")
              : `导入完成，共 ${payload.importedCount || 0} 条。`;
            setStatus(summary);
          } catch (error) {
            setStatus(`导入失败：${error instanceof Error ? error.message : String(error)}`, true);
          } finally {
            importBtn.disabled = false;
          }
        });
      }

      (async () => {
        syncAdminUi();
        await loadAdminState();
        await loadEntries();
        renderAll();
      })();
    })();
  </script>

