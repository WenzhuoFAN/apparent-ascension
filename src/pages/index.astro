---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import TagPills from "../components/TagPills.astro";

import { getAllRecommendations } from "../lib/recommendations";

const { clips, fanworks } = await getAllRecommendations();
const latestRecs = [...clips, ...fanworks]
  .sort((a, b) => (b.createdAt ?? "").localeCompare(a.createdAt ?? ""))
  .slice(0, 6);
---

<BaseLayout title="闪耀舞台" description="入坑导航、日程表、直播记录、精选与数据">
  <NavBar slot="nav" active="home" />

  <Hero
    title="闪耀舞台 · 粉丝导航站"
    tagline="给新粉一条最短入坑路径，信息入口：日程表、直播记录、粉丝数据、精选内容。"
  />

  <Section title="本周日程" subtitle="按北京时间计算当前周（周一至周日）。">
    <div id="home-schedule-list"></div>
    <p class="p" id="home-schedule-empty" hidden>暂无已保存日程。</p>
  </Section>

  <Section title="最新推荐">
    <div class="grid cols-3">
      {latestRecs.map((r) => (
        <a class="rec" href={r.url} target="_blank" rel="noreferrer" data-member={r.member} data-tags={r.tags.join(",")}>
          <div class="rt">{r.title}</div>
          <div class="rd">{r.reason ?? ""}</div>
          <div class="meta">
            <span class="pill">{r.member}</span>
            <span class="pill faint">{r.kind}</span>
          </div>
          <TagPills tags={r.tags.slice(0, 3)} />
        </a>
      ))}
    </div>
  </Section>

  <script is:inline>
    (() => {
      const contentKey = "schedule.manual.entries.v3";
      const listEl = document.getElementById("home-schedule-list");
      const emptyEl = document.getElementById("home-schedule-empty");
      if (!listEl || !emptyEl) return;

      const roomLabelMap = {
        fiona: "心宜",
        gladys: "思诺",
      };
      const roomCoverMap = {
        fiona: "/images/FionaLive.jpg",
        gladys: "/images/GladysLive.jpg",
      };

      const formatDateCN = (date) => {
        const m = String(date || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!m) return date || "--";
        return `${Number(m[1])}年${Number(m[2])}月${Number(m[3])}日`;
      };

      const sortEntries = (entries) =>
        [...entries].sort((a, b) => `${a.date}T${a.time}`.localeCompare(`${b.date}T${b.time}`));

      const DAY_MS = 24 * 60 * 60 * 1000;
      const BJ_TZ = "Asia/Shanghai";
      const weekdayMap = {
        Sun: 0,
        Mon: 1,
        Tue: 2,
        Wed: 3,
        Thu: 4,
        Fri: 5,
        Sat: 6,
      };

      const toUtcDayTs = (year, month, day) => Date.UTC(year, month - 1, day);

      const getBeijingDateParts = (date = new Date()) => {
        const parts = new Intl.DateTimeFormat("en-US", {
          timeZone: BJ_TZ,
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          weekday: "short",
        }).formatToParts(date);

        const pick = (type) => parts.find((p) => p.type === type)?.value || "";
        return {
          year: Number(pick("year")),
          month: Number(pick("month")),
          day: Number(pick("day")),
          weekday: pick("weekday"),
        };
      };

      const getCurrentBeijingWeekRange = () => {
        const today = getBeijingDateParts(new Date());
        const weekDay = weekdayMap[today.weekday] ?? 0;
        const mondayOffset = (weekDay + 6) % 7; // Mon=0 ... Sun=6
        const todayTs = toUtcDayTs(today.year, today.month, today.day);
        const weekStartTs = todayTs - mondayOffset * DAY_MS;
        const weekEndTs = weekStartTs + 6 * DAY_MS;
        return { weekStartTs, weekEndTs };
      };

      const parseEntryDateTs = (dateStr) => {
        const m = String(dateStr || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
        if (!m) return NaN;
        return toUtcDayTs(Number(m[1]), Number(m[2]), Number(m[3]));
      };

      const pickCurrentWeek = (entries) => {
        const { weekStartTs, weekEndTs } = getCurrentBeijingWeekRange();
        return entries.filter((entry) => {
          const dateTs = parseEntryDateTs(entry.date);
          return Number.isFinite(dateTs) && dateTs >= weekStartTs && dateTs <= weekEndTs;
        });
      };

      const createRow = (entry) => {
        const row = document.createElement("a");
        row.className = "schedule-row";
        row.href = "/schedule";
        row.setAttribute("aria-label", `${entry.title || "未命名日程"}，查看完整日程`);

        const main = document.createElement("div");
        main.className = "schedule-main";

        const when = document.createElement("div");
        when.className = "schedule-when";
        when.textContent = `${formatDateCN(entry.date)} ${entry.time}`;

        const title = document.createElement("div");
        title.className = "schedule-title";
        title.textContent = entry.title || "未命名日程";

        const meta = document.createElement("div");
        meta.className = "schedule-meta";
        meta.textContent = `直播间：${roomLabelMap[entry.room] || entry.room || "--"}`;
        main.append(when, title, meta);

        const coverWrap = document.createElement("div");
        coverWrap.className = "schedule-cover-wrap";
        const cover = document.createElement("img");
        cover.className = "schedule-cover";
        cover.alt = "";
        cover.loading = "lazy";
        cover.src = roomCoverMap[entry.room] || roomCoverMap.fiona;
        cover.onerror = () => {
          coverWrap.hidden = true;
        };
        coverWrap.appendChild(cover);

        row.append(main, coverWrap);
        return row;
      };

      const render = (entries) => {
        listEl.innerHTML = "";
        if (!entries.length) {
          emptyEl.hidden = false;
          return;
        }
        emptyEl.hidden = true;
        entries.forEach((entry) => listEl.appendChild(createRow(entry)));
      };

      const load = async () => {
        try {
          const response = await fetch(`/api/content/${encodeURIComponent(contentKey)}`, { cache: "no-store" });
          const json = await response.json();
          if (!response.ok || !json?.ok || !Array.isArray(json.data)) {
            render([]);
            return;
          }

          const normalized = json.data.filter((entry) => {
            if (!entry || typeof entry !== "object") return false;
            if (typeof entry.title !== "string") return false;
            if (typeof entry.date !== "string") return false;
            if (typeof entry.time !== "string") return false;
            if (entry.room !== "fiona" && entry.room !== "gladys") return false;
            return true;
          });

          render(sortEntries(pickCurrentWeek(normalized)));
        } catch {
          render([]);
        }
      };

      load();
    })();
  </script>

  <style lang="scss">
  @use "../styles/mixins" as m;

  #home-schedule-list{
    display: grid;
    gap: 14px;
  }

  :global(.schedule-row){
    @include m.glass;
    @include m.hover-float;
    border-radius: var(--r-lg);
    padding: 12px;
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 12px;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }
  :global(.schedule-main){
    min-width: 0;
  }
  :global(.schedule-when){
    font-size: 13px;
    color: rgba(255,255,255,.72);
    margin-bottom: 6px;
  }
  :global(.schedule-title){
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  :global(.schedule-meta){
    color: rgba(255,255,255,.62);
    font-size: 13px;
  }
  :global(.schedule-cover-wrap){
    justify-self: end;
    width: 100%;
    min-height: 120px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(0,0,0,.2);
  }
  :global(.schedule-cover){
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 0;
    border: 0;
    box-shadow: none;
    transform: translateZ(0);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  :global(.schedule-row:hover .schedule-cover){
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,.22);
  }

  .rec{
    @include m.glass;
    @include m.hover-float;
    border-radius: var(--r-lg);
    padding: 14px 14px;
    display: block;
  }
  .rt{ font-weight: 700; margin-bottom: 6px; }
  .rd{ color: rgba(255,255,255,.65); font-size: 13px; min-height: 34px; }
  .meta{ display:flex; gap: 8px; flex-wrap: wrap; margin: 10px 0 8px; }

  @media (max-width: 860px){
    :global(.schedule-row){
      grid-template-columns: 1fr;
      padding: 14px;
    }
    :global(.schedule-cover-wrap){
      justify-self: start;
      width: 100%;
    }
  }
  </style>
</BaseLayout>

<style lang="scss">
:global(.page){
  background: transparent !important;
  border: 0 !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
  padding: 0 !important;
}
</style>
