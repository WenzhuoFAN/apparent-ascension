---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";

import { LIVE_STATUS_BY_KEY, fetchLiveStatusByMid } from "../lib/bilibili-live";
import { CONTENT_KEYS, getContentByKey } from "../lib/content-store";

type ScheduleRoom = "fiona" | "gladys" | "both";
type ScheduleEntry = {
  id: string;
  title: string;
  date: string;
  time: string;
  room: ScheduleRoom;
  category?: string;
  mode?: string;
  tags?: string[];
};

type HomeLatestRecommendation = {
  id: string;
  url: string;
  title: string;
  cover?: string;
  reason?: string;
  createdAt?: string;
};

const latestRecs = [...((await getContentByKey(CONTENT_KEYS.homeLatest)) as HomeLatestRecommendation[])]
  .sort((a, b) => String(b.createdAt || "").localeCompare(String(a.createdAt || "")))
  .slice(0, 6);

const roomLabelMap = {
  fiona: "心宜",
  gladys: "思诺",
  both: "双人",
} satisfies Record<ScheduleRoom, string>;

const roomCoverMap = {
  fiona: "/images/FionaLive.jpg",
  gladys: "/images/GladysLive.jpg",
} satisfies Record<Exclude<ScheduleRoom, "both">, string>;

const scheduleEntries = ((await getContentByKey(CONTENT_KEYS.schedule)) as ScheduleEntry[]).filter((entry) => {
  if (!entry || typeof entry !== "object") return false;
  if (typeof entry.title !== "string" || typeof entry.date !== "string" || typeof entry.time !== "string") return false;
  return entry.room === "fiona" || entry.room === "gladys" || entry.room === "both";
});

const formatDateCN = (date: string) => {
  const m = String(date || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return date || "--";
  return `${Number(m[1])}年${Number(m[2])}月${Number(m[3])}日`;
};

const getBeijingNowKey = () => {
  const parts = new Intl.DateTimeFormat("en-CA", {
    timeZone: "Asia/Shanghai",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  }).formatToParts(new Date());

  const pick = (type: string) => parts.find((part) => part.type === type)?.value || "";
  return `${pick("year")}-${pick("month")}-${pick("day")}T${pick("hour")}:${pick("minute")}`;
};

const byDateTimeAsc = (a: ScheduleEntry, b: ScheduleEntry) =>
  `${a.date}T${a.time}`.localeCompare(`${b.date}T${b.time}`);

const nowKey = getBeijingNowKey();
const pickNextEntryForMember = (member: Exclude<ScheduleRoom, "both">) =>
  scheduleEntries
    .filter((entry) => entry.room === member || entry.room === "both")
    .filter((entry) => `${entry.date}T${entry.time}` >= nowKey)
    .sort(byDateTimeAsc)[0] ?? null;

const liveStatuses = Object.fromEntries(
  await Promise.all(
    (Object.keys(LIVE_STATUS_BY_KEY) as Array<Exclude<ScheduleRoom, "both">>).map(async (member) => [
      member,
      await fetchLiveStatusByMid(LIVE_STATUS_BY_KEY[member]),
    ]),
  ),
) as Record<Exclude<ScheduleRoom, "both">, Awaited<ReturnType<typeof fetchLiveStatusByMid>>>;

const nextStreams = [
  {
    member: "fiona" as const,
    label: roomLabelMap.fiona,
    cover: roomCoverMap.fiona,
    entry: pickNextEntryForMember("fiona"),
    href: liveStatuses.fiona?.liveUrl || `https://space.bilibili.com/${LIVE_STATUS_BY_KEY.fiona}`,
  },
  {
    member: "gladys" as const,
    label: roomLabelMap.gladys,
    cover: roomCoverMap.gladys,
    entry: pickNextEntryForMember("gladys"),
    href: liveStatuses.gladys?.liveUrl || `https://space.bilibili.com/${LIVE_STATUS_BY_KEY.gladys}`,
  },
];
---

<BaseLayout title="闪耀舞台" description="入坑导航、日程表、直播记录、精选与数据">
  <NavBar slot="nav" active="home" />

  <Hero
    title="闪耀舞台 · 粉丝导航站"
    tagline="给新粉一条最短入坑路径，信息入口：日程表、直播记录、粉丝数据、精选内容。"
  />

  <Section title="下一场直播">
    <div class="home-next-grid">
      {nextStreams.map(({ member, label, cover, entry, href }) => (
        <a class={`home-next-card ${member}`} href={href} target="_blank" rel="noreferrer" aria-label={`${label}下一场直播，前往直播间`}>
          <div class="home-next-copy">
            <div class="home-next-member">{label}</div>
            {
              entry ? (
                <>
                  <div class="home-next-title-row">
                    <div class="home-next-title">{entry.title}</div>
                    {entry.mode && <span class="home-next-pill">{entry.mode}</span>}
                  </div>
                  <div class="home-next-when">{formatDateCN(entry.date)} {entry.time}</div>
                  <div class="home-next-meta">
                    直播间：{roomLabelMap[entry.room]}
                    {entry.category ? ` · ${entry.category}` : ""}
                  </div>
                </>
              ) : (
                <>
                  <div class="home-next-empty">暂无安排</div>
                  <div class="home-next-meta">有新日程时会在这里更新。</div>
                </>
              )
            }
          </div>
          <div class="home-next-cover-wrap">
            <img class="home-next-cover" src={cover} alt={`${label}直播封面`} loading="lazy" width="180" height="112" />
          </div>
        </a>
      ))}
    </div>
  </Section>

  <Section title="最新推荐">
    <div class="admin-bar">
      <button class="admin-btn" id="open-home-rec-admin" type="button" hidden>编辑</button>
    </div>

    <div class="grid cols-3" id="home-rec-grid">
      {latestRecs.map((r) => (
        <a class="rec rec-custom" href={r.url} target="_blank" rel="noreferrer" data-rec-key={r.id}>
          <div class="rt">{r.title}</div>
          {r.cover && <img class="cover" src={r.cover} alt="" loading="lazy" referrerpolicy="no-referrer" />}
          <div class="rd">{r.reason ?? ""}</div>
        </a>
      ))}
    </div>
    <p class="p" id="home-rec-empty" hidden={latestRecs.length > 0}>还没有“最新推荐”条目，登录管理员后点击“编辑”添加。</p>
  </Section>

  <div class="admin-modal" id="home-rec-modal" hidden>
    <div class="admin-panel">
      <div class="admin-head">
        <h3>最新推荐编辑</h3>
        <button class="admin-close" id="close-home-rec-admin" type="button" aria-label="关闭">×</button>
      </div>

      <div class="admin-grid">
        <label class="field full">
          <span>B 站视频链接</span>
          <input id="home-rec-link-input" placeholder="https://www.bilibili.com/video/BV..." type="url" />
        </label>

        <div class="field actions">
          <span>自动配置</span>
          <button class="admin-btn" id="fetch-home-rec-meta" type="button">抓取标题和封面</button>
        </div>

        <label class="field full">
          <span>标题</span>
          <input id="home-rec-title-input" placeholder="自动抓取后可再手改" type="text" />
        </label>

        <label class="field full">
          <span>封面链接</span>
          <input id="home-rec-cover-input" placeholder="自动抓取后会填好" type="url" />
        </label>

        <div class="field full">
          <span>封面预览</span>
          <img class="cover-preview" id="home-rec-cover-preview" alt="" hidden />
        </div>

        <label class="field full">
          <span>推荐说明</span>
          <textarea id="home-rec-reason-input" rows="3" placeholder="比如：这条先看，信息密度高。"></textarea>
        </label>
      </div>

      <p class="admin-status" id="home-rec-status"></p>

      <div class="admin-actions">
        <button class="admin-btn primary" id="save-home-rec-entry" type="button">保存到首页</button>
        <button class="admin-btn" id="cancel-home-rec-entry" type="button">取消</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ storageKey: CONTENT_KEYS.homeLatest, initialRecs: latestRecs }}>
    (() => {
      const STORAGE_KEY = storageKey;
      const VIEW_API = "https://api.bilibili.com/x/web-interface/view";
      let isAdmin = false;
      let editMode = false;
      let itemsState = Array.isArray(initialRecs) ? [...initialRecs] : [];

      const gridEl = document.getElementById("home-rec-grid");
      const emptyEl = document.getElementById("home-rec-empty");
      const openBtn = document.getElementById("open-home-rec-admin");
      const modal = document.getElementById("home-rec-modal");
      const closeBtn = document.getElementById("close-home-rec-admin");
      const cancelBtn = document.getElementById("cancel-home-rec-entry");
      const fetchBtn = document.getElementById("fetch-home-rec-meta");
      const saveBtn = document.getElementById("save-home-rec-entry");

      const linkInput = document.getElementById("home-rec-link-input");
      const titleInput = document.getElementById("home-rec-title-input");
      const coverInput = document.getElementById("home-rec-cover-input");
      const reasonInput = document.getElementById("home-rec-reason-input");
      const coverPreview = document.getElementById("home-rec-cover-preview");
      const statusEl = document.getElementById("home-rec-status");

      if (!gridEl || !emptyEl || !openBtn || !modal || !closeBtn || !cancelBtn || !fetchBtn || !saveBtn) return;
      if (!linkInput || !titleInput || !coverInput || !reasonInput || !coverPreview || !statusEl) return;

      const contentUrl = (key, admin = false) =>
        `${admin ? "/api/admin/content/" : "/api/content/"}${encodeURIComponent(key)}`;

      const fetchJson = async (url, init = {}) => {
        const response = await fetch(url, { cache: "no-store", ...init });
        let payload = null;
        try {
          payload = await response.json();
        } catch {
          payload = null;
        }
        return { response, payload };
      };

      const normalizeUrl = (url) => String(url || "").trim();
      const normalizeCover = (url) => normalizeUrl(url).replace(/^http:\/\//i, "https://");

      const showStatus = (msg, isErr = false) => {
        statusEl.textContent = msg || "";
        statusEl.classList.toggle("err", !!isErr);
      };

      const parseVideoId = (url) => {
        const raw = normalizeUrl(url);
        if (!raw) return null;

        const bv = raw.match(/BV[0-9A-Za-z]{10}/i);
        if (bv) return { bvid: bv[0] };

        const av = raw.match(/(?:\/av|aid=)(\d+)/i);
        if (av) return { aid: av[1] };

        return null;
      };

      const fetchViaJsonp = (url, timeoutMs = 12000) =>
        new Promise((resolve, reject) => {
          const callbackName = `__bili_jsonp_${Date.now()}_${Math.floor(Math.random() * 1e6)}`;
          const joiner = url.includes("?") ? "&" : "?";
          const script = document.createElement("script");
          let timer = null;

          const cleanup = () => {
            if (timer) clearTimeout(timer);
            delete window[callbackName];
            script.remove();
          };

          window[callbackName] = (payload) => {
            cleanup();
            resolve(payload);
          };

          script.onerror = () => {
            cleanup();
            reject(new Error("JSONP network error"));
          };

          timer = setTimeout(() => {
            cleanup();
            reject(new Error("JSONP timeout"));
          }, timeoutMs);

          script.src = `${url}${joiner}jsonp=jsonp&callback=${callbackName}`;
          document.head.appendChild(script);
        });

      const loadItems = async () => {
        try {
          const { response, payload } = await fetchJson(contentUrl(STORAGE_KEY));
          if (!response.ok || !payload?.ok || !Array.isArray(payload.data)) {
            itemsState = [];
            return;
          }
          itemsState = payload.data;
        } catch {
          itemsState = [];
        }
      };

      const loadAdminState = async () => {
        try {
          const { response, payload } = await fetchJson("/api/admin/session");
          if (!response.ok) {
            isAdmin = false;
          } else {
            isAdmin = !!payload?.authenticated;
          }
        } catch {
          isAdmin = false;
        }

        openBtn.hidden = !isAdmin;
      };

      const writeItems = async (rows) => {
        itemsState = Array.isArray(rows) ? rows : [];
        if (!isAdmin) return true;

        const { response, payload } = await fetchJson(contentUrl(STORAGE_KEY, true), {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ data: itemsState }),
        });

        if (response.status === 401) {
          isAdmin = false;
          editMode = false;
          openBtn.hidden = true;
          showStatus("管理员会话已失效，请先去 /admin 登录。", true);
          renderCards();
          return false;
        }

        if (!response.ok || !payload?.ok || !Array.isArray(payload.data)) {
          showStatus(`保存失败：${payload?.message || response.statusText}`, true);
          return false;
        }

        itemsState = payload.data;
        return true;
      };

      const createCard = (item) => {
        const a = document.createElement("a");
        a.className = "rec rec-custom";
        a.href = item.url;
        a.target = "_blank";
        a.rel = "noreferrer";
        a.dataset.recKey = item.id;

        const t = document.createElement("div");
        t.className = "rt";
        t.textContent = item.title;
        a.appendChild(t);

        if (item.cover) {
          const img = document.createElement("img");
          img.className = "cover";
          img.src = item.cover;
          img.alt = "";
          img.loading = "lazy";
          img.referrerPolicy = "no-referrer";
          a.appendChild(img);
        }

        if (item.reason) {
          const d = document.createElement("div");
          d.className = "rd";
          d.textContent = item.reason;
          a.appendChild(d);
        }

        return a;
      };

      const setCardLinksEnabled = (enabled) => {
        gridEl.querySelectorAll("a.rec-custom").forEach((card) => {
          const anchor = card;
          if (!(anchor instanceof HTMLAnchorElement)) return;

          if (enabled) {
            const saved = anchor.dataset.hrefSaved;
            if (saved && !anchor.hasAttribute("href")) anchor.setAttribute("href", saved);
            anchor.removeAttribute("aria-disabled");
            return;
          }

          if (anchor.hasAttribute("href")) {
            anchor.dataset.hrefSaved = anchor.getAttribute("href") || "";
          }
          anchor.removeAttribute("href");
          anchor.setAttribute("aria-disabled", "true");
        });
      };

      const updateEmptyState = () => {
        const hasItems = gridEl.querySelectorAll(".rec:not(.rec-add-slot):not([hidden])").length > 0;
        emptyEl.hidden = hasItems;
      };

      const removeDeleteButtons = () => {
        document.querySelectorAll(".rec-delete").forEach((x) => x.remove());
      };

      const deleteCard = async (card) => {
        const recKey = card.getAttribute("data-rec-key") || "";
        if (!recKey) return;
        const title = card.querySelector(".rt")?.textContent?.trim() || "该条目";
        if (!confirm(`确定删除「${title}」吗？`)) return;

        const next = itemsState.filter((x) => x.id !== recKey);
        const ok = await writeItems(next);
        if (!ok) return;
        renderCards();
      };

      const renderDeleteButtons = () => {
        removeDeleteButtons();
        if (!isAdmin || !editMode) return;

        document.querySelectorAll(".rec-custom").forEach((card) => {
          const del = document.createElement("button");
          del.type = "button";
          del.className = "rec-delete";
          del.textContent = "×";
          del.setAttribute("aria-label", "删除条目");
          del.addEventListener("click", async (event) => {
            event.preventDefault();
            event.stopPropagation();
            await deleteCard(card);
          });
          card.appendChild(del);
        });
      };

      const renderAddSlots = () => {
        document.querySelectorAll(".rec-add-slot").forEach((x) => x.remove());
        if (!isAdmin || !editMode) return;

        const visibleCount = gridEl.querySelectorAll(".rec:not(.rec-add-slot):not([hidden])").length;
        const slots = Math.max(0, 6 - visibleCount);

        for (let i = 0; i < slots; i += 1) {
          const add = document.createElement("button");
          add.type = "button";
          add.className = "rec rec-add-slot";
          add.innerHTML = '<span class="plus">+</span>';
          add.addEventListener("click", () => openModal());
          gridEl.appendChild(add);
        }
      };

      const renderCards = () => {
        gridEl.innerHTML = "";
        const rows = [...itemsState].sort((a, b) => String(b.createdAt || "").localeCompare(String(a.createdAt || ""))).slice(0, 60);
        rows.forEach((item) => gridEl.appendChild(createCard(item)));
        setCardLinksEnabled(!editMode);
        renderDeleteButtons();
        renderAddSlots();
        updateEmptyState();
      };

      const resetForm = () => {
        linkInput.value = "";
        titleInput.value = "";
        coverInput.value = "";
        reasonInput.value = "";
        coverPreview.hidden = true;
        coverPreview.removeAttribute("src");
        showStatus("");
      };

      const openModal = () => {
        if (!isAdmin || !editMode) return;
        modal.hidden = false;
      };

      const closeModal = () => {
        modal.hidden = true;
        resetForm();
      };

      const syncCoverPreview = () => {
        const src = normalizeCover(coverInput.value);
        if (!src) {
          coverPreview.hidden = true;
          coverPreview.removeAttribute("src");
          return;
        }
        coverPreview.src = src;
        coverPreview.hidden = false;
      };

      const fetchMeta = async () => {
        if (!isAdmin) return;
        const link = normalizeUrl(linkInput.value);
        const id = parseVideoId(link);

        if (!id) {
          showStatus("链接里没识别到 BV / av 号。", true);
          return;
        }

        showStatus("正在抓取标题和封面...");

        const applyMetaFromPayload = (json) => {
          if (!json || json.code !== 0 || !json.data) {
            throw new Error(json?.message || "B 站接口返回异常");
          }
          titleInput.value = json.data.title || "";
          coverInput.value = normalizeCover(json.data.pic || "");
          syncCoverPreview();
        };

        try {
          const qs = new URLSearchParams(id).toString();
          const apiUrl = `${VIEW_API}?${qs}`;

          try {
            const resp = await fetch(apiUrl);
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            const json = await resp.json();
            applyMetaFromPayload(json);
            showStatus("已自动填好标题和封面。");
            return;
          } catch {
            const jsonpPayload = await fetchViaJsonp(apiUrl);
            applyMetaFromPayload(jsonpPayload);
            showStatus("已通过兼容模式抓取标题和封面。");
          }
        } catch (err) {
          const msg = err instanceof Error ? err.message : String(err);
          showStatus(`抓取失败：${msg}。可手动填写。`, true);
        }
      };

      const saveEntry = async () => {
        if (!isAdmin) return;
        const item = {
          id: (globalThis.crypto?.randomUUID?.() || `${Date.now()}-${Math.random()}`).toString(),
          url: normalizeUrl(linkInput.value),
          title: normalizeUrl(titleInput.value),
          cover: normalizeCover(coverInput.value),
          reason: normalizeUrl(reasonInput.value),
          createdAt: new Date().toISOString(),
        };

        if (!item.url) {
          showStatus("请先输入视频链接。", true);
          return;
        }
        if (!item.title) {
          showStatus("请先抓取或填写标题。", true);
          return;
        }

        const next = [item, ...itemsState].slice(0, 60);
        const ok = await writeItems(next);
        if (!ok) return;

        renderCards();
        closeModal();
      };

      const setEditMode = (next) => {
        if (!isAdmin) return;
        editMode = next;
        openBtn.textContent = editMode ? "完成" : "编辑";
        if (!editMode) closeModal();
        renderCards();
      };

      openBtn.addEventListener("click", () => setEditMode(!editMode));
      closeBtn.addEventListener("click", closeModal);
      cancelBtn.addEventListener("click", closeModal);
      fetchBtn.addEventListener("click", fetchMeta);
      saveBtn.addEventListener("click", saveEntry);
      coverInput.addEventListener("input", syncCoverPreview);
      linkInput.addEventListener("change", () => {
        if (normalizeUrl(linkInput.value)) fetchMeta();
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && !modal.hidden) closeModal();
      });

      modal.addEventListener("click", (event) => {
        if (event.target === modal) closeModal();
      });

      (async () => {
        await Promise.all([loadItems(), loadAdminState()]);
        renderCards();
      })();
    })();
  </script>

  <style lang="scss">
  @use "../styles/mixins" as m;

  .home-next-grid{
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  :global(.home-next-card){
    @include m.glass;
    @include m.hover-float;
    border-radius: var(--r-lg);
    padding: 16px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 156px;
    gap: 16px;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }
  :global(.home-next-copy){
    min-width: 0;
  }
  :global(.home-next-member){
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    margin-bottom: 12px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .08em;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.12);
  }
  :global(.home-next-card.fiona .home-next-member){
    background: rgba(244, 125, 177, .16);
    border-color: rgba(244, 125, 177, .28);
  }
  :global(.home-next-card.gladys .home-next-member){
    background: rgba(123, 133, 255, .16);
    border-color: rgba(123, 133, 255, .28);
  }
  :global(.home-next-title-row){
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 8px;
  }
  :global(.home-next-when){
    font-size: 13px;
    color: rgba(255,255,255,.72);
    margin-bottom: 6px;
  }
  :global(.home-next-title),
  :global(.home-next-empty){
    font-size: 22px;
    font-weight: 700;
    line-height: 1.2;
    flex: 1 1 auto;
    min-width: 0;
  }
  :global(.home-next-pill){
    display: inline-flex;
    align-items: center;
    min-height: 22px;
    padding: 0 8px;
    border-radius: 999px;
    background: rgba(255,255,255,.10);
    border: 1px solid rgba(255,255,255,.16);
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }
  :global(.home-next-meta){
    color: rgba(255,255,255,.62);
    font-size: 13px;
  }
  :global(.home-next-cover-wrap){
    justify-self: end;
    width: 100%;
    max-width: 156px;
    min-height: 96px;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.14);
    background: rgba(0,0,0,.2);
  }
  :global(.home-next-cover){
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform .2s ease, filter .2s ease;
  }
  :global(.home-next-card:hover .home-next-cover){
    transform: translateY(-2px);
    filter: saturate(1.06);
  }

  :global(a.rec-custom){
    @include m.glass;
    @include m.hover-float;
    border-radius: var(--r-lg);
    padding: 14px;
    display: block;
    position: relative;
  }
  :global(.rec-custom .cover){
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 12px;
